{
  "tasks": {
    "lint": "deno lint",
    "format": "deno fmt",
    "build": "deno task --cwd=apps/ui build",
    "preview": "deno task --cwd=apps/ui preview",
    "dev": "sh dev.sh",
    "backend:start": "cd backend/ && bash start.sh",
    "backend:stop": "cd backend/ && bash stop.sh",
    "api:start": "deno run --allow-net --allow-read apps/api/index.ts",
    "ui:start": "deno task --cwd=apps/ui dev",
    "schema:generate": "cd backend/ && powersync generate schema --output-path=../apps/ui/src/schema.ts --output=ts"
  },
  "imports": {
    "@std/http": "jsr:@std/http@^1.0.25"
  }
}
